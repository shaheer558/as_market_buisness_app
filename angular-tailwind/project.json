{
  "name": "angular-tailwind",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "angular-tailwind/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/angular-tailwind",
        "main": "angular-tailwind/src/index.ts",
        "tsConfig": "angular-tailwind/tsconfig.lib.json",
        "assets": [
          "angular-tailwind/*.md",
          {
            "input": "./angular-tailwind/src",
            "glob": "**/!(*.ts)",
            "output": "./src"
          },
          {
            "input": "./angular-tailwind/src",
            "glob": "**/*.d.ts",
            "output": "./src"
          },
          {
            "input": "./angular-tailwind",
            "glob": "generators.json",
            "output": "."
          },
          {
            "input": "./angular-tailwind",
            "glob": "executors.json",
            "output": "."
          }
        ]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "angular-tailwind/jest.config.cts"
      }
    }
  }
}
